# =============================================================================
# Environment Configuration
# =============================================================================

# Environment selector (local, prod)
APP_ENV=local
NODE_ENV=development

# =============================================================================
# Server Configuration
# =============================================================================

PORT=3002

# Timezone (IANA timezone format)
TIMEZONE=Asia/Kolkata

# =============================================================================
# Database Configuration
# =============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=ecommerce_db
DATABASE_SSL="true"

# For production, use these:
# PROD_DATABASE_HOST=
# PROD_DATABASE_PORT=
# PROD_DATABASE_USER=
# PROD_DATABASE_PASSWORD=
# PROD_DATABASE_NAME=

# =============================================================================
# Logging Configuration
# =============================================================================

LOG_LEVEL=debug
LOG_ERRORS=true
LOG_SUCCESS=false
LOG_FILE_ENABLED=true
LOG_DIR=./logs

# =============================================================================
# Security Configuration
# =============================================================================

JWT_SECRET=your-secret-key-change-in-production
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=ecommerce-secret-key-2026

# =============================================================================
# Media Tooling
# =============================================================================
# Optional: full path to the ffmpeg binary (or the folder containing it).
# Required only when saving m3u8/mpd captures into the local library — they get
# converted to mp4 via ffmpeg before being stored. Leave empty if ffmpeg is on PATH.
# Examples:
#   Windows binary:  FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
#   Windows folder:  FFMPEG_PATH=C:\ffmpeg\bin
#   Linux/macOS:     FFMPEG_PATH=/usr/local/bin/ffmpeg
FFMPEG_PATH=

# Google Drive credentials were removed when storage moved to R2.
# Library bytes + social upload bytes both come from R2 (`file_url`).

# Firebase Cloud Messaging credentials are read directly from
# `backend/firebase-service-account.json` (not from this file). Paste the
# service-account JSON downloaded from Firebase Console into that file.

# =============================================================================
# Google OAuth (SSO)
# =============================================================================
# Web client ID from Google Cloud Console → APIs & Services → Credentials.
# Used to validate the `aud` claim on Google ID tokens sent from the mobile
# app (token_type=id_token). Leave empty to skip audience validation.
GOOGLE_CLIENT_ID=
